# ── Copia este fichero a .env y rellena los valores ──
# (.env NO se versiona; .env.example sí)

# Entorno de la app
ENVIRONMENT=local
APP_NAME=productive-rag

# OpenAI (servicio REAL de internet, no se simula en LocalStack)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL + pgvector (contenedor propio = "RDS" simulado)
POSTGRES_USER=rag
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=ragdb
# Host 'postgres' = nombre del servicio en docker-compose
DATABASE_URL=postgresql+asyncpg://rag:ragpass@postgres:5432/ragdb

# Redis (memoria a corto plazo)
REDIS_URL=redis://redis:6379/0

# LocalStack (AWS simulado)
AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=dnd-manuals
S3_MANUAL_KEY=player-handbook.pdf

# Auth (JWT propio) — genera una clave fuerte para producción
JWT_SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
